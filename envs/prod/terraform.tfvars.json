{
  "aws_region": "eu-west-1",
  "environment": "prod",
  "service": "nginx",
  "project": "ecs-nginx",
  "additional_tags": {
    "Owner": "team-name",
    "CostCenter": "cost_center_name"
  },
  "vpc_cidr": "10.0.0.0/16",
  "availability_zones": [
    "eu-west-2a",
    "eu-west-2b"
  ],
  "public_subnet_cidrs": [
    "10.0.0.0/24",
    "10.0.1.0/24"
  ],
  "web_subnet_cidrs": [
    "10.0.2.0/24",
    "10.0.3.0/24"
  ],
  "database_subnet_cidrs": [
    "10.0.5.0/24",
    "10.0.6.0/24"
  ],
  "acm_certificate_arn": "arn:aws:acm:<az>:<account_d>:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
  "container_image": "nginx:1.1.0",
  "container_port": 80,
  "health_check_path": "/",
  "ecs_cpu": 256,
  "ecs_memory": 512,
  "desired_count": 3,
  "enable_execute_command": true,
  "autoscaling_min_capacity": 3,
  "autoscaling_max_capacity": 8,
  "autoscaling_cpu_target": 60,
  "log_retention_in_days": 30,
  "alb_deletion_protection": true,
  "alb_access_log_bucket_name": null,
  "db_name": "appdb",
  "db_master_username": "appadmin",
  "db_engine": "postgres",
  "db_engine_version": "13",
  "db_instance_class": "db.t3.micro",
  "db_allocated_storage_gb": 100,
  "db_port": 5432,
  "multi_az_db": true,
  "backup_retention_period": 0,
  "db_deletion_protection": false,
  "db_apply_immediately": false,
  "kms_key_id": null,
  "create_dns_record": true,
  "route53_zone_name": "example.com",
  "dns_name":         "api",
  "zone_id":   "zone_id"
}
